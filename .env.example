# Copy this file to .env and adjust as needed.

# HTTP port for the dashboard server
PORT=3000

# How often (ms) to poll price / holders / transfers
POLL_INTERVAL_MS=60000

# Plasmascan (Blockscout) block explorer API base.
# Verify this matches the live explorer before relying on the data --
# Blockscout instances occasionally host the API on a separate subdomain.
PLASMASCAN_API_BASE=https://plasmascan.to/api/v2

# CoinGecko API id for XPL (visible as "API ID" on the coin's CoinGecko page)
COINGECKO_COIN_ID=plasma

# CoinGecko API base (free tier, no key required for basic endpoints)
COINGECKO_API_BASE=https://api.coingecko.com/api/v3

# DefiLlama unlocks API (best-effort; falls back to the static schedule in
# server/services/unlocks.js if this project slug doesn't resolve)
DEFILLAMA_EMISSIONS_URL=https://api.llama.fi/emissions/plasma

# A single native-XPL transfer at/above this amount is treated as a
# "whale transfer" and shown in the large-transfer feed.
LARGE_TRANSFER_XPL=250000

# How many of the newest transactions to scan per poll cycle for large
# transfers. Raise this if you poll infrequently, lower it to reduce API load.
TX_SCAN_LIMIT=200

# Total XPL supply, used for % concentration calculations (see tokenomics)
TOTAL_SUPPLY_XPL=10000000000
